{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "concurrently -k -n vite,electron -c blue,magenta \"vite\" \"wait-on http://127.0.0.1:5173 && cross-env ELECTRON_DEV=1 electron .\"",
    "dev": "npm start",
    "start:ui-only": "concurrently -k -n vite,electron -c blue,magenta \"vite\" \"wait-on http://127.0.0.1:5173 && cross-env ELECTRON_DEV=1 GHOST_WRITER_UI_ONLY=1 electron .\"",
    "build": "tsc -b && vite build",
    "build:app": "vite build && electron-builder --mac",
    "start:dist": "electron .",
    "lint": "eslint ."
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "wait-on": "^9.0.5",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.ghostwriter.app",
    "productName": "GhostWriter",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../dist/ghost_backend",
        "to": "ghost_backend"
      },
      {
        "from": "../config",
        "to": "config"
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities"
    }
  }
}
